{
  "name": "e2e-cypress-test",
  "version": "1.0.0",
  "description": "Projeto de testes E2E para Frontend e API do ServeRest usando Cypress",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:ui": "cypress run --spec 'cypress/e2e/ui/**'",
    "test:api": "cypress run --spec 'cypress/e2e/api/**'",
    "test:all": "cypress run",
    "test:chrome": "cypress run --browser chrome",
    "test:firefox": "cypress run --browser firefox",
    "test:headed": "cypress run --headed",
    "test:report": "cypress run --reporter cypress-mochawesome-reporter"
  },
  "keywords": [
    "cypress",
    "e2e",
    "testing",
    "automation",
    "api-testing",
    "ui-testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "cypress": "^15.11.0",
    "cypress-mochawesome-reporter": "^3.8.4"
  }
}
